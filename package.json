{
  "name": "zanflo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "npm --prefix frontend install && npm --prefix frontend run build",
    "deploy": "npm run build && wrangler deploy",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "reset:dev-db": "node scripts/reset-dev-db.js --confirm-reset",
    "test": "vitest run --maxWorkers=1 --minWorkers=1"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "wrangler": "^4.82.2"
  }
}
